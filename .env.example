# MuseWrite 环境变量配置
# 复制此文件为 .env 并填写实际值

# 服务配置
NODE_ENV=production
PORT=18062

# ===========================================
# LLM API Keys (按需填写，至少配置一个)
# ===========================================

# 国际主流
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini                    # 可选: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

ANTHROPIC_API_KEY=sk-ant-xxx                # Claude
CLAUDE_MODEL=claude-3-5-sonnet-20241022     # 可选: claude-3-opus, claude-3-haiku

GOOGLE_API_KEY=xxx                          # Google Gemini
GEMINI_MODEL=gemini-1.5-flash               # 可选: gemini-1.5-pro

MISTRAL_API_KEY=xxx                         # Mistral AI
MISTRAL_MODEL=mistral-small-latest

GROQ_API_KEY=xxx                            # Groq (超快推理)
GROQ_MODEL=llama-3.3-70b-versatile

COHERE_API_KEY=xxx                          # Cohere
COHERE_MODEL=command

XAI_API_KEY=xxx                             # xAI Grok
XAI_MODEL=grok-beta

# 国内主流
ZHIPU_API_KEY=xxx                           # 智谱 GLM
ZHIPU_MODEL=glm-4                           # 可选: glm-4-flash, glm-4-plus

DEEPSEEK_API_KEY=sk-xxx                     # DeepSeek
DEEPSEEK_MODEL=deepseek-chat                # 可选: deepseek-coder

DASHSCOPE_API_KEY=xxx                       # 通义千问 (阿里云)
QWEN_MODEL=qwen-turbo                       # 可选: qwen-plus, qwen-max

MOONSHOT_API_KEY=xxx                        # Kimi (月之暗面)
MOONSHOT_MODEL=moonshot-v1-8k

VOLCENGINE_API_KEY=xxx                      # 火山引擎 (豆包)
VOLCENGINE_MODEL=doubao-pro-32k

WENXIN_API_KEY=xxx                          # 百度文心一言
WENXIN_MODEL=ernie-4.0-8k

MINIMAX_API_KEY=xxx                         # MiniMax
MINIMAX_MODEL=abab6.5-chat

# OpenAI 兼容 API (通用)
AI_API_KEY=xxx
AI_API_ENDPOINT=https://your-api-endpoint/v1/chat/completions
AI_MODEL=default

# ===========================================
# 配图 API
# ===========================================
SEEDDREAM_API_KEY=xxx
SEEDDREAM_API_URL=https://api.seeddream.ai

# ===========================================
# 安全配置
# ===========================================
JWT_SECRET=your-random-secret-key-here
API_KEY_SALT=your-random-salt-here

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=info
