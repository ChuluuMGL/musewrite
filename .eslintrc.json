{
  "env": {
    "node": true,
    "es2024": true,
    "jest": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single", "avoid-escape"],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "ignoreRestSiblings": true, "caughtErrors": "all", "caughtErrorsIgnorePattern": "^_", "destructuredArrayIgnorePattern": "^_" }],
    "no-undef": "error",
    "prefer-const": "warn",
    "no-console": "off",
    "prefer-template": "warn",
    "comma-dangle": ["error", "never"],
    "no-multiple-empty-lines": "warn",
    "no-trailing-spaces": "warn",
    "max-len": ["warn", { "code": 150, "ignoreUrls": true, "ignoreTemplateLiterals": true }],
    "no-async-promise-executor": "off"
  }
}
